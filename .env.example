# ═══════════════════════════════════════════════════════════════
# SALES COACH — Environment Variables
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values
# NEVER commit .env to git!
# ═══════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────
# SUPABASE
# Get these from: https://supabase.com/dashboard → Project Settings → API
# ─────────────────────────────────────────────────────────────────
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# ─────────────────────────────────────────────────────────────────
# REVENUECAT
# Get these from: https://app.revenuecat.com → Project → API Keys
# ─────────────────────────────────────────────────────────────────
EXPO_PUBLIC_REVENUECAT_IOS=
EXPO_PUBLIC_REVENUECAT_ANDROID=

# ─────────────────────────────────────────────────────────────────
# POSTHOG (Analytics)
# Get this from: https://posthog.com → Project Settings → API Key
# ─────────────────────────────────────────────────────────────────
EXPO_PUBLIC_POSTHOG_KEY=

# ─────────────────────────────────────────────────────────────────
# ENVIRONMENT
# Values: development | staging | production
# ─────────────────────────────────────────────────────────────────
EXPO_PUBLIC_APP_ENV=development

# ═══════════════════════════════════════════════════════════════
# AI KEYS — DO NOT PUT HERE!
# ═══════════════════════════════════════════════════════════════
# Add AI keys to Supabase Edge Function secrets only:
#   supabase secrets set ANTHROPIC_API_KEY=sk-ant-...
#
# This keeps API keys out of client code and version control.
# ═══════════════════════════════════════════════════════════════
